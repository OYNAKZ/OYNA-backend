APP_NAME=OYNA Backend
APP_ENV=development
APP_VERSION=0.1.0
DEBUG=true
API_PREFIX=/api/v1
SQLALCHEMY_ECHO=false
DATABASE_URL=postgresql://postgres:postgres@db:5432/oyna
JWT_SECRET_KEY=change-me
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
LOG_LEVEL=INFO
AUTH_PASSWORD_MIN_LEN=10
AUTH_PASSWORD_MAX_LEN=128
AUTH_REQUIRE_EMAIL_VERIFICATION=false
AUTH_ANTI_ENUMERATION=false
AUTH_PASSWORD_HASH_SCHEME=bcrypt_sha256
AUTH_BCRYPT_ROUNDS=12
RESERVATION_HOLD_TTL_SECONDS=900
PAYMENT_PROVIDER_DEFAULT=fake
